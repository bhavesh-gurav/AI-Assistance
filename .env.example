# ---- Gemini / AI ----
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=http://generativelanguage.googleapis.com/v1beta
GEMINI_TEMPERATURE=0.3
REQUEST_TIMEOUT_SECONDS=60

# ---- Assistant ----
ASSISTANT_NAME=Jarvis
WAKE_WORD=hey jarvis
# false = continuous conversation (listen->respond->listen). true = require "hey jarvis" first.
REQUIRE_WAKE_WORD=false
# Seconds of silence that mark the end of your command before Jarvis responds.
COMMAND_END_SILENCE=2.0
REQUIRE_CONFIRMATION=true
CONVERSATION_WINDOW=12
LOG_LEVEL=INFO

# ---- Speech to text (faster-whisper) ----
# model sizes: tiny.en, base.en, small.en, medium.en, large-v3
WHISPER_MODEL_SIZE=base.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
MIC_RECORD_SECONDS=5
MIC_SAMPLE_RATE=16000
# Optional: force a specific input device index (see the list printed by the mic test).
# Leave blank to use the Windows default microphone.
INPUT_DEVICE=

# ---- Text to speech (pyttsx3) ----
TTS_RATE=185
# Partial voice name to prefer, e.g. "David" or "Zira" on Windows. Leave blank for default.
TTS_VOICE=

# ---- Paths (optional overrides) ----
# DATABASE_PATH=data/jarvis.db
# OUTPUT_DIR=generated_files
